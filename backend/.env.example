# Stock Radar System — Environment Configuration

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/stock_radar

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production

# Trading Parameters
TRADING_MODE=paper
MAX_POSITION_SIZE=5000.0
MAX_CONCURRENT_POSITIONS=5
STOP_LOSS_PCT=0.05
DAILY_LOSS_LIMIT=500.0
TARGET_PROFIT_PER_SHARE_MIN=0.10
TARGET_PROFIT_PER_SHARE_MAX=0.25

# Universe Filter
UNIVERSE_MIN_PRICE=1.0
UNIVERSE_MAX_PRICE=10.0
UNIVERSE_MIN_VOLUME=100000

# IBKR (Phase 1b — TWS Paper Trading)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
